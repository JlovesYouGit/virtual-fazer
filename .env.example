# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=instagran
DB_USER=postgres
DB_PASSWORD=password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Django Configuration
DEBUG=True
SECRET_KEY=django-insecure-change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=10080

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Neural Interface Configuration
NEURAL_MODEL_PATH=/app/neural_models
NEURAL_CACHE_TIMEOUT=3600
NEURAL_BATCH_SIZE=32

# Auto-follow Configuration
AUTO_FOLLOW_ENABLED=True
AUTO_FOLLOW_THRESHOLD=0.8
AUTO_FOLLOW_MAX_PER_DAY=50

# Go Service Configuration
DATABASE_URL=host=localhost user=postgres dbname=instagran password=password port=5432 sslmode=disable

# Node.js Configuration
FRONTEND_URL=http://localhost:3000
PORT=3000

# File Upload Configuration
MAX_UPLOAD_SIZE=100MB
UPLOAD_PATH=/app/uploads

# Email Configuration (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Sidekiq Configuration
SIDEKIQ_REDIS_URL=redis://localhost:6379/0

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log

# Security Configuration
ENCRYPTION_KEY=your-32-character-encryption-key
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_BROWSER_XSS_FILTER=True

# Monitoring Configuration
SENTRY_DSN=
PROMETHEUS_ENABLED=False

# Performance Configuration
CACHE_TTL=300
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Development Configuration
DEVELOPMENT=True
PRODUCTION=False
