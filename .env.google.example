# Google OAuth 2.0 Configuration
# Get these values from: https://console.developers.google.com/

# Google Client ID (Web Application)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google Client Secret
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google OAuth Redirect URI
GOOGLE_REDIRECT_URI=http://localhost:8000/accounts/google/login/callback/

# Google OAuth Scopes
GOOGLE_SCOPES=openid email profile

# Frontend URLs for Google OAuth
FRONTEND_URL=http://localhost:3000
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Enable/Disable Google OAuth
GOOGLE_OAUTH_ENABLED=True

# Auto-link Google accounts on registration
GOOGLE_AUTO_LINK_ON_REGISTER=True

# Additional Google API settings
GOOGLE_API_KEY=your-google-api-key
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=path/to/service-account-key.json
